    echo -e "${Y}Ruta esperada:${N} $path"
    echo -e "${Y}Estado:${N} En desarrollo..."
    pause
  fi
}

# ═══════════════════════════════════════════════════════
#  SERVICIOS / PUERTOS  ─ VERSIÓN OPTIMIZADA
# ═══════════════════════════════════════════════════════
#
# Problema anterior: se hacían ~15 cmd_timeout secuenciales
# (grep config, systemctl, jq, ss, etc.) cada uno con hasta
# 0.5 s de espera. Ahora se hace UNA SOLA llamada a ss y
# se lee cada config solo si el servicio está corriendo.
# Todo en <0.3 s en el peor caso.
# ═══════════════════════════════════════════════════════

_build_services_cache() {
  # 1) Capturar TODOS los sockets
  local ss_output
  ss_output="$(ss -Hlntup 2>/dev/null)" || ss_output=""

  # 2) Armar un array asociativo
  declare -A svc_ports=()

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue

    # EXTRAER COLUMNAS NATIVAMENTE (Sin awk)
    # ss output: Netid  State  Recv-Q Send-Q  LocalAddress:Port  PeerAddress:Port  Process
    read -r netid state recv send local_addr peer rest <<< "$line"

    # Detectar protocolo (Sin grep)
    local proto="TCP"
    [[ "$netid" == udp* || "$netid" == UNCONN* || "$state" == UNCONN* ]] && proto="UDP"

    # Extraer puerto (Sin awk)
    local port="${local_addr##*:}"
    [[ -z "$port" || ! "$port" =~ ^[0-9]+$ ]] && continue

    # Extraer nombre del proceso (Sin sed, usando Regex nativo de Bash)
    local proc=""
    if [[ "$rest" =~ users:\(\(\"([^\"]+)\" ]]; then
      proc="${BASH_REMATCH[1]}"
    fi
    [[ -z "$proc" ]] && continue

    # Normalizar nombre del servicio (Tu lógica exacta)
    local svc_name=""
    case "$proc" in
      sshd)              svc_name="SSH" ;;
      dropbear)          svc_name="Dropbear" ;;
      v2ray)             svc_name="V2Ray" ;;
      xray)              svc_name="Xray" ;;
      squid|squid3)      svc_name="Squid" ;;
      stunnel|stunnel4)  svc_name="Stunnel" ;;
      openvpn)           svc_name="OpenVPN" ;;
      badvpn-udpgw)      svc_name="BadVPN" ;;
      python3|python)    svc_name="Python" ;;
      nginx)             svc_name="Nginx" ;;
      apache2|httpd)     svc_name="Apache" ;;
      node)              svc_name="Node.js" ;;
      udp-custom|udpgw)  svc_name="UDP-Custom" ;;
      wireguard-go|wg)   svc_name="WireGuard" ;;
      *)                 svc_name="$proc" ;;
    esac

    # Saltar puertos UDP dinámicos
    if [[ "$proto" == "UDP" && ("$svc_name" == "V2Ray" || "$svc_name" == "Xray" || "$svc_name" == "BadVPN") ]]; then
      continue
    fi

    local port_label="$port"
    [[ "$proto" == "UDP" ]] && port_label="${port}(UDP)"

    # Agregar al mapa evitando duplicados y LIMITANDO LA CANTIDAD
    if [[ -z "${svc_ports[$svc_name]:-}" ]]; then
      svc_ports[$svc_name]="$port_label"
    elif [[ "${svc_ports[$svc_name]}" != *"$port_label"* ]]; then
      
      # Cuenta cuántas comas hay rápido (para saber cuántos puertos van)
      local current="${svc_ports[$svc_name]}"
      local comas="${current//[^,]/}" 
      
      # Si hay menos de 6 puertos, lo agrega normal. Si hay más, pone "..."
      if (( ${#comas} < 5 )); then
        svc_ports[$svc_name]="${current}, $port_label"
      elif [[ "$current" != *"..."* ]]; then
        svc_ports[$svc_name]="${current}, ..."
      fi
    fi
  done <<< "$ss_output"

  # 3) Agregar WireGuard desde config
  if [[ -z "${svc_ports[WireGuard]:-}" ]] && ls /etc/wireguard/*.conf &>/dev/null; then
    local wg_port
    wg_port="$(grep -hE '^ListenPort' /etc/wireguard/*.conf 2>/dev/null | awk '{print $3}' | head -1)"
    [[ -n "$wg_port" ]] && svc_ports["WireGuard"]="${wg_port}(UDP)"
  fi

  # 4) Convertir a texto plano
  _SERVICES_CACHE=""
  for svc in "${!svc_ports[@]}"; do
    _SERVICES_CACHE+="${svc}=${svc_ports[$svc]}"$'\n'
  done
}

show_services_status() {
  hr
  echo -e "${W}                   SERVICIOS ACTIVOS${N}"
  hr

  # Construir cache (una sola vez, ~0.1 s)
  _build_services_cache

  if [[ -z "$_SERVICES_CACHE" ]]; then
    echo -e "${Y}No se encontraron servicios activos con puertos.${N}"
    hr
    echo ""
    return 0
  fi

  # Leer lineas en un array
  local -a lines=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && lines+=("$line")
  done <<< "$_SERVICES_CACHE"

  local count="${#lines[@]}"
  local half=$(( (count + 1) / 2 ))

  # ── Anchos fijos para alinear las dos columnas ──
  # COL_NAME  = ancho reservado para el nombre del servicio (ej: "SSH", "WireGuard")
  # COL_TOTAL = ancho total de la columna izquierda (nombre + ": " + puertos)
  local COL_NAME=2
  local COL_TOTAL=28

  for ((i = 0; i < half; i++)); do
    local left="${lines[$i]}"
    local left_svc="${left%%=*}"
    local left_ports="${left#*=}"

    # Columna izquierda: nombre con ancho fijo + ": " + puertos
    # Luego se rellena hasta COL_TOTAL para que la columna derecha arranque igual
    local left_plain
    left_plain="$(printf "%-${COL_NAME}s: %s" "$left_svc" "$left_ports")"
    printf "${C}%-${COL_NAME}s${W}: ${G}%s${N}" "$left_svc" "$left_ports"

    # Padding hasta COL_TOTAL caracteres (basado en texto plano sin colores)
    local left_len="${#left_plain}"
    local pad=$(( COL_TOTAL - left_len ))
    (( pad > 0 )) && printf "%${pad}s" ""
    # Separador entre columnas
    printf ""

    # Columna derecha
    local right_idx=$((i + half))
    if (( right_idx < count )); then
      local right="${lines[$right_idx]}"
      local right_svc="${right%%=*}"
      local right_ports="${right#*=}"
      printf "${C}%-${COL_NAME}s${W}: ${G}%s${N}" "$right_svc" "$right_ports"
    fi

    echo ""
  done

  sep
}

