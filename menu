    DISTRO="${PRETTY_NAME:-$(uname -rs)}"
  else
    DISTRO="$(uname -rs)"
  fi

  IP_PUBLICA="$(get_public_ip)"
  USUARIO="$(whoami)"
  ZONA_HORARIA="$(timedatectl 2>/dev/null | awk -F': ' '/Time zone/ {print $2}' | awk '{print $1}' || date +%Z)"
  read -r MEM_TOTAL MEM_USADA MEM_LIBRE <<< "$(free -m | awk '/^Mem:/ {print $2, $3, $7}')"

  DOMINIO=""
  [[ -f "/etc/SN/dominio.txt" ]] && DOMINIO="$(cat /etc/SN/dominio.txt)"

  SWAP_INFO=""
  local swap_total
  swap_total=$(free -m | awk '/^Swap:/ {print $2}')
  if [[ "$swap_total" -gt 0 ]]; then
    local swap_used swap_free
    swap_used=$(free -m | awk '/^Swap:/ {print $3}')
    swap_free=$(free -m | awk '/^Swap:/ {print $4}')
    SWAP_INFO="${Y}${swap_total} MB${W} > Uso: ${Y}${swap_used} MB${W} > Libre: ${G}${swap_free} MB${N}"
  fi
}

