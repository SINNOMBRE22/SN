# ── Utilidades ──────────────────────────────────────────
cmd_timeout() {
  local seconds="$1"; shift
  timeout "$seconds" bash -c "$*" 2>/dev/null
}

get_public_ip() {
  cmd_timeout 0.2 "curl -fsS https://api.ipify.org" \
  || cmd_timeout 0.5 "curl -fsS ifconfig.me" \
  || echo "No disponible"
}

